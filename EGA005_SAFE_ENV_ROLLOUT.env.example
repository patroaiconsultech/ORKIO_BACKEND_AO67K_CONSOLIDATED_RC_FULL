# EGA-005 — PHASE 1: observe-only, no behavior break
AUTO_SCHEMA_HOTFIX_DIRECT=false
EVOLUTION_MUTATION_AUTHORITY_REQUIRED=false

# Existing GitHub controls remain closed by default.
GITHUB_AUTOMATION_ALLOWED=false
AUTO_CODE_EMISSION_ENABLED=false
GITHUB_PR_RUNTIME_ENABLED=false
ALLOW_GITHUB_MAIN_DIRECT=false

# Approval lifetime, used when enforcement is enabled.
EVOLUTION_APPROVAL_TTL_SECONDS=3600

# Per-action mutation flags — keep false until controlled validation.
EVOLUTION_ALLOW_DIRECT_SCHEMA=false
EVOLUTION_ALLOW_CREATE_BRANCH=false
EVOLUTION_ALLOW_WRITE_FILE=false
EVOLUTION_ALLOW_CREATE_COMMIT=false
EVOLUTION_ALLOW_OPEN_PR=false
EVOLUTION_ALLOW_MERGE_PR=false
EVOLUTION_ALLOW_DEPLOY=false
EVOLUTION_ALLOW_ROLLBACK=true

# EGA-005 — PHASE 2: controlled enforcement
# Set only after smoke tests and dashboard payload updates:
# EVOLUTION_MUTATION_AUTHORITY_REQUIRED=true
# EVOLUTION_ALLOW_CREATE_BRANCH=true
# EVOLUTION_ALLOW_WRITE_FILE=true
# EVOLUTION_ALLOW_OPEN_PR=true
# EVOLUTION_ALLOW_MERGE_PR=true
#
# Keep permanently false:
# EVOLUTION_ALLOW_DIRECT_SCHEMA=false
# EVOLUTION_ALLOW_DEPLOY=false

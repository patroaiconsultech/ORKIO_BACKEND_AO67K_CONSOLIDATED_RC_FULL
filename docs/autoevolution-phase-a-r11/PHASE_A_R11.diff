+            max_length=128,
+        ),
+        "authority_scope": _safe_text(
+            authority_scope,
+            default="not_applicable",
+            max_length=64,
+        ),
+        "governance_flags": governance_flags,
+    }
+
+
+def emit_boot_identity(
+    logger: logging.Logger,
+    app: Any,
+    *,
+    app_version: str,
+    repo_root: Optional[Path] = None,
+    runtime_main_path: Optional[Path] = None,
